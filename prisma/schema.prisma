generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Team {
  ally
  enemy
  neutral
}

model UnitDefinition {
  id                Int    @id @default(autoincrement())
  slug              String @unique
  maxHp             Int
  attack            Int
  speed             Float  @default(80)
  /// Golpes por segundo (p. ej. 1 = cada 1000 ms)
  attacksPerSecond  Float  @default(1)
  team              Team
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GameRule {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
